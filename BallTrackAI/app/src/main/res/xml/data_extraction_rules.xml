<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ equivalent of backup_rules.xml. Excludes face data and
    violation clips from both cloud backup AND device-to-device transfer,
    since the "stays on this device" guarantee should hold even when
    setting up a new phone.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="local_face_data/" />
        <exclude domain="file" path="violation_clips/" />
        <exclude domain="file" path="match_recordings/" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="local_face_data/" />
        <exclude domain="file" path="violation_clips/" />
        <exclude domain="file" path="match_recordings/" />
    </device-transfer>
</data-extraction-rules>
